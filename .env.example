# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real private keys.

# Bitcoin Core RPC (regtest defaults)
RPC_URL=http://127.0.0.1:18443
RPC_USER=user
RPC_PASS=password

# SV2 Mining Protocol server address
SV2_LISTEN_ADDR=0.0.0.0:3333

# Pool fallback payout address (used when miner does not supply a valid BTC address)
POOL_ADDRESS=bcrt1qyourpooladdresshere

# SV2 Noise NX authority keypair — generate with: just keygen
POOL_AUTHORITY_PUBLIC_KEY=<64 hex chars>
POOL_AUTHORITY_PRIVATE_KEY=<64 hex chars>
